{
  "sites": {
    "www_mimimi_top": {
      "name": "www.mimimi.top",
      "base_url": "https://www.mimimi.top",
      "groups": [
        {
          "name": "图片",
          "resource_type": "art",
          "entry_points": [
            {
              "name": "mimimi.top/arttype/8",
              "url": "https://www.mimimi.top/arttype/85.html",
              "type": "art"
            }
          ],
          "link_patterns": {
            "art_detail": [
              "/artdetail-\\d+\\.html"
            ],
            "exclude": [
              "/arttype/",
              "/artsearch/",
              "/static/"
            ]
          },
          "crawl_pattern": {
            "list_crawl": {
              "steps": [
                {
                  "action": "navigate"
                },
                {
                  "action": "smart_wait",
                  "selector": "a[href], .item, article, main"
                },
                {
                  "action": "extract_links",
                  "source": "markdown",
                  "link_type": "art_detail"
                }
              ],
              "pagination": {
                "methods": [
                  "button_click",
                  "url_construct"
                ],
                "max_pages": 100
              }
            },
            "level_1": {
              "steps": [
                {
                  "action": "navigate"
                },
                {
                  "action": "smart_wait",
                  "selector": "img[src], .art-content, .content, .pic"
                },
                {
                  "action": "network_capture",
                  "filter": ".jpg,.jpeg,.png,.webp,.gif",
                  "wait_seconds": 3
                }
              ]
            }
          }
        }
      ],
      "site_type": "maccms"
    }
  }
}