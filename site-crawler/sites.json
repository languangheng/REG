{
  "sites": {
    "www_mimimi_top": {
      "name": "www.mimimi.top",
      "base_url": "https://www.mimimi.top",
      "groups": [
        {
          "name": "图片",
          "resource_type": "art",
          "entry_points": [
            {
              "name": "Just a moment...",
              "url": "https://www.mimimi.top/arttype/8.html",
              "type": "art"
            }
          ],
          "link_patterns": {
            "art_detail": [
              "/artdetail-\\d+\\.html"
            ],
            "exclude": [
              "/arttype/\\d+\\.html"
            ]
          },
          "extract_chains": {
            "art": {
              "steps": [
                {
                  "name": "enter_detail",
                  "method": "navigate"
                },
                {
                  "name": "capture_images",
                  "method": "network_capture",
                  "filter": ".jpg,.jpeg,.png,.webp,.gif",
                  "wait_seconds": 3
                }
              ]
            }
          },
          "crawl_pattern": {
            "list_crawl": {
              "steps": [
                {
                  "action": "navigate",
                  "url_template": ""
                },
                {
                  "action": "smart_wait",
                  "selector": "a[href], .item, article, main"
                },
                {
                  "action": "extract_links",
                  "source": "markdown",
                  "link_type": "art_detail"
                }
              ],
              "pagination": {
                "methods": [
                  "button_click",
                  "url_construct"
                ],
                "max_pages": 100
              }
            },
            "level_1": {
              "steps": [
                {
                  "action": "navigate",
                  "url_template": "/artdetail-{id}.html"
                },
                {
                  "action": "smart_wait",
                  "selector": "img[src], .art-content, .content, .pic"
                },
                {
                  "action": "network_capture",
                  "filter": ".jpg,.jpeg,.png,.webp,.gif",
                  "wait_seconds": 3
                }
              ]
            }
          }
        }
      ]
    }
  }
}