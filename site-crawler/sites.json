{
  "sites": {
    "www_mimimi_top": {
      "name": "www.mimimi.top",
      "base_url": "https://www.mimimi.top",
      "groups": [
        {
          "name": "www.mimimi.top",
          "resource_type": "video",
          "entry_points": [
            {
              "name": "www.mimimi.top",
              "url": "https://www.mimimi.top/vodshow/12-----------.html",
              "type": "video"
            }
          ],
          "link_patterns": {
            "video_detail": [
              "/voddetail/\\d+\\.html"
            ],
            "play_page": [
              "/vodplay/\\d+-\\d+-\\d+\\.html"
            ]
          },
          "crawl_pattern": {
            "chain_order": [
              "list_crawl",
              "level_1",
              "stream_capture"
            ],
            "list_crawl": {
              "name": "list_crawl",
              "steps": [
                {
                  "action": "navigate"
                },
                {
                  "action": "smart_wait",
                  "selector": "a[href*='/vodshow/']"
                },
                {
                  "action": "extract_links",
                  "source": "markdown",
                  "link_type": "level_1"
                }
              ],
              "pagination": {
                "methods": [
                  "url_construct"
                ],
                "url_construct": {
                  "format": "maccms",
                  "url_template": "/vodshow/12--------{page}---.html"
                },
                "max_pages": 100
              }
            },
            "level_1": {
              "name": "level_1",
              "steps": [
                {
                  "action": "navigate"
                },
                {
                  "action": "smart_wait",
                  "selector": "a[href*='/voddetail/']"
                },
                {
                  "action": "extract_links",
                  "source": "markdown",
                  "link_type": "resource"
                }
              ]
            },
            "stream_capture": {
              "name": "stream_capture",
              "steps": [
                {
                  "action": "navigate"
                },
                {
                  "action": "smart_wait",
                  "selector": "video, iframe[src], .player, #player, .video-box"
                },
                {
                  "action": "network_capture",
                  "filter": ".m3u8,.mp4,.flv,.ts",
                  "wait_seconds": 5
                }
              ]
            }
          }
        }
      ]
    }
  }
}